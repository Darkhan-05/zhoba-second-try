generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Session {
  id        String     @id @default(uuid())
  topic     String
  roomCode  String     @unique
  createdAt DateTime   @default(now())
  questions Question[]
  answers   Answer[]
}

model Question {
  id        String   @id @default(uuid())
  content   String
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  answers   Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  studentName String
  hatColor    String
  content     String
  createdAt   DateTime @default(now())
  sessionId   String
  questionId  String
  session     Session  @relation(fields: [sessionId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])
}

model InviteToken {
  id        String   @id
  code      String   @unique
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdBy String
  User      User?
}

model User {
  id            String      @id
  username      String
  loginId       String      @unique
  deviceId      String
  createdAt     DateTime    @default(now())
  favorites     String
  inviteTokenId String      @unique
  InviteToken   InviteToken @relation(fields: [inviteTokenId], references: [id])
}
